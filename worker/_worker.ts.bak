export interface Env {
  OPENAI_KEY: string;
  OPENAI_BETA?: string;
  OPENAI_ORG_ID?: string;
  OPENAI_PROJECT?: string;
  UPSTREAM_REALTIME?: string; // "1" to enable upstream; else echo-mode could be added
}

export default {
  async fetch(req: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
    const url = new URL(req.url);

    // WS endpoint only
    if (url.pathname === "/v1/realtime") {
      if (req.headers.get("Upgrade")?.toLowerCase() !== "websocket") {
        // Avoid "hung code" when someone does a plain GET in dev/preview
        return new Response("Expected WebSocket upgrade", { status: 426 });
      }

      // Accept client socket
      const pair = new WebSocketPair();
      const [client, server] = Object.values(pair);
      server.accept();

      // Prepare upstream connection to OpenAI Realtime
      const model = url.searchParams.get("model") ?? "gpt-4o-realtime-preview-2024-12-17";
      const upstreamUrl = `https://api.openai.com/v1/realtime?model=${encodeURIComponent(model)}`;

      const proto = req.headers.get("Sec-WebSocket-Protocol") ?? undefined;
      const headers = new Headers({
        "Upgrade": "websocket",
        "Authorization": `Bearer ${env.OPENAI_KEY}`,
        "OpenAI-Beta": "realtime=v1"
      });
      if (proto) headers.set("Sec-WebSocket-Protocol", proto);
      if (env.OPENAI_ORG_ID) headers.set("OpenAI-Organization", env.OPENAI_ORG_ID);
      if (env.OPENAI_PROJECT) headers.set("OpenAI-Project", env.OPENAI_PROJECT);

      // Open upstream WebSocket via fetch+Upgrade
      const upstreamResp = await fetch(upstreamUrl, { headers });
      const upstream = (upstreamResp as any).webSocket as WebSocket | undefined;
      if (!upstream) {
        server.close(1011, "Upstream ws not available");
        return new Response("Failed to connect upstream", { status: 502 });
      }
      upstream.accept();

      // Bridge messages both ways
      server.addEventListener("message", (ev: MessageEvent) => {
        try { upstream.send(ev.data); } catch { /* ignore send errors */ }
      });
      upstream.addEventListener("message", (ev: MessageEvent) => {
        try { server.send(ev.data); } catch { /* ignore send errors */ }
      });

      // Mirror close/error in both directions
      server.addEventListener("close", (ev: CloseEvent) => {
        try { upstream.close(ev.code, ev.reason || "client closed"); } catch {}
      });
      upstream.addEventListener("close", (ev: CloseEvent) => {
        try { server.close(ev.code, ev.reason || "upstream closed"); } catch {}
      });
      server.addEventListener("error", () => {
        try { upstream.close(1011, "client error"); } catch {}
      });
      upstream.addEventListener("error", () => {
        try { server.close(1011, "upstream error"); } catch {}
      });

      // Keep-alive ping from server to avoid idle disconnects
      const ping = setInterval(() => {
        try {
          server.send(JSON.stringify({ type: "ping", t: Date.now() }));
        } catch {
          clearInterval(ping);
        }
      }, 30000);

      // Ensure the worker stays alive until one side closes
      ctx.waitUntil(new Promise<void>((resolve) => {
        const done = () => { clearInterval(ping); resolve(); };
        server.addEventListener("close", done);
        upstream.addEventListener("close", done);
      }));

      // Complete the client handshake; include subprotocol if provided
      const respHeaders = new Headers();
      if (proto) respHeaders.set("Sec-WebSocket-Protocol", proto);
      return new Response(null, { status: 101, webSocket: client, headers: respHeaders });
    }

    // Fallback for other paths
    return new Response("OK", { status: 200 });
  }
};

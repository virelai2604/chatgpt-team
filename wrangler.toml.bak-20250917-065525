name = "chatgpt-team-realtime"
main = "_worker.ts"
compatibility_date = "2025-09-16"

[vars]
# The realtime Worker needs this header to opt into the Realtime API
OPENAI_BETA = "realtime=v1"
# OPENAI_KEY should be set as a secret in the Cloudflare Dashboard or via:
#   wrangler secret put OPENAI_KEY
# Optional:
#   wrangler secret put OPENAI_ORG_ID
#   wrangler secret put OPENAI_PROJECT
